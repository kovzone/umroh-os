{
  "name": "core-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "UmrohOS front-gate web app — operator console, status page, future admin/dashboard surface.",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript ../../services/gateway-svc/api/rest_oapi/openapi.yaml -o src/lib/api/gateway/schema.d.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.17.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/svelte": "^5.2.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.10.5",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.5.0",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.4"
  }
}
