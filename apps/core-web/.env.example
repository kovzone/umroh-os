# Browser-side base URL for gateway-svc. Used by src/lib/api/gateway/client.ts.
# In dev: the browser hits the host-mapped port. In prod: the deployed gateway URL.
VITE_GATEWAY_URL=http://localhost:4000

# S1 catalog pages (BL-FE-BOOK-002):
# - true  => use local mock dataset
# - false => call live catalog endpoints at VITE_CATALOG_API_BASE_URL
VITE_USE_CATALOG_MOCK=true

# Base URL for catalog API calls used by S1 catalog repository.
# Keep as gateway URL when gateway exposes /v1/packages* routes.
VITE_CATALOG_API_BASE_URL=http://localhost:4000

# S1 draft booking form (BL-FE-BOOK-003):
# - true  => submit via local mock response
# - false => call live booking endpoint /v1/bookings
VITE_USE_BOOKING_MOCK=true

# Base URL for booking API calls used by S1 booking repository.
# Keep as gateway URL when gateway exposes /v1/bookings.
VITE_BOOKING_API_BASE_URL=http://localhost:4000
