# =============================================================================
# UmrohOS — Production Environment Template
# =============================================================================
# Copy this file to the server as /home/infra/umrohos/.env.prod
# Fill in all values marked CHANGE_ME before first deploy.
# NEVER commit the real .env.prod file to git.
#
# Usage:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Generate secrets (examples):
#   openssl rand -base64 24        # strong random password (~32 chars; good for DB/Grafana)
#   openssl rand -hex 16           # exactly 32 hex chars — use for TOKEN_KEY and TOTP_ENCRYPTION_KEY (iam-svc)
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=umrohos

# Must match POSTGRES_* above. Used by the migrate service and all backend svcs.
DATABASE_URL=postgres://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/umrohos?sslmode=disable

# Connection string used by Go services (overrides config.json.sample).
POSTGRES_CONNECTION_STRING=postgres://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/umrohos?sslmode=disable

# -----------------------------------------------------------------------------
# core-web — Vite build args (public browser URL for API gateway)
# Browser-side JS runs in the user's browser, not inside Docker,
# so this must be the public-facing URL (server IP or domain).
# -----------------------------------------------------------------------------
VITE_PUBLIC_GATEWAY_URL=http://216.176.238.161:4000
# Runtime origin used by SvelteKit server for CSRF same-origin validation.
CORE_WEB_ORIGIN=http://216.176.238.161

# -----------------------------------------------------------------------------
# iam-svc — Token and TOTP secrets
# -----------------------------------------------------------------------------
# Paseto symmetric key — must be exactly 32 characters (string length == 32).
# Do NOT use `openssl rand -base64 32` (that yields ~44 characters). Use e.g.:
#   openssl rand -hex 16
TOKEN_KEY=CHANGE_ME_REPLACE_WITH_32_BYTE_PASETO_SECRET

# AES-256 key for TOTP encryption — exactly 32 bytes as the config string (same rule: 32 chars for ASCII).
# Use a different value than TOKEN_KEY, e.g. second run of: openssl rand -hex 16
TOTP_ENCRYPTION_KEY=CHANGE_ME_REPLACE_WITH_32_BYTE_AES_KEY

# -----------------------------------------------------------------------------
# Grafana admin credentials
# Change the default admin password before exposing Grafana (even via tunnel).
# -----------------------------------------------------------------------------
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# OpenTelemetry — optional overrides
# Defaults in config.json.sample already point at otel-collector:4317.
# Uncomment only if you need to override per-service tracer settings.
# -----------------------------------------------------------------------------
# OTEL_TRACER_ENDPOINT=otel-collector:4317

# -----------------------------------------------------------------------------
# Notes on config.json.sample mounts
# -----------------------------------------------------------------------------
# Each Go service has its config.json.sample bind-mounted read-only as
# /app/config.json inside the container. The sample file contains
# sensible defaults for service-to-service gRPC addresses and pool settings.
#
# Secrets that MUST come from this env file (not the sample JSON):
#   - POSTGRES_CONNECTION_STRING  →  store.postgres.connection_string
#   - TOKEN_KEY                   →  token.key          (iam-svc only)
#   - TOTP_ENCRYPTION_KEY         →  totp.encryption_key (iam-svc only)
#
# The services read env vars on startup and override the JSON config values.
# Refer to each service's main.go / config loader for exact env var names.
