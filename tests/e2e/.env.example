# Service base URLs (host ports from docker-compose.dev.yml).
# Prefer 127.0.0.1 for API/gateway so Playwright's Node client uses IPv4 (localhost -> ::1 often fails).
IAM_SVC_URL=http://127.0.0.1:4001
GATEWAY_SVC_URL=http://127.0.0.1:4000
# Browser specs: use localhost for core-web on Docker Desktop + Windows (127.0.0.1:3001 can mis-route).
CORE_WEB_URL=http://localhost:3001
