#!/usr/bin/env bash
# Pre-push hook — blocks push if type checks or Go builds fail.
# Install once: git config core.hooksPath .githooks

set -euo pipefail

# ── Load nvm / Homebrew node so npm and go are available ───────────────────
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
# shellcheck disable=SC1091
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh" --no-use

# Homebrew (Apple Silicon + Intel)
for brew_prefix in /opt/homebrew /usr/local; do
  [ -d "$brew_prefix/bin" ] && export PATH="$brew_prefix/bin:$PATH"
done

# Use nvm default node if node not yet on PATH
if ! command -v node &>/dev/null && command -v nvm &>/dev/null; then
  nvm use default --silent 2>/dev/null || true
fi

# ── Helper: check if a file path was touched in this push ──────────────────
changed_in() {
  git diff --name-only HEAD @{u} 2>/dev/null | grep -q "^$1" || \
  git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -q "^$1"
}

echo "▶ pre-push: running checks before push..."

# ── Frontend: svelte-check ──────────────────────────────────────────────────
if changed_in "apps/core-web/"; then
  if ! command -v npm &>/dev/null; then
    echo "  ⚠ npm not found on PATH — skipping svelte-check (CI will catch it)"
  else
    echo "  → svelte-check (core-web)..."
    (cd apps/core-web && npm run check) || {
      echo ""
      echo "✗ svelte-check failed. Fix type errors before pushing."
      exit 1
    }
    echo "  ✓ svelte-check passed"
  fi
fi

# ── Backend: go build for each changed service ─────────────────────────────
SERVICES="gateway-svc iam-svc catalog-svc booking-svc payment-svc finance-svc logistics-svc ops-svc visa-svc jamaah-svc crm-svc"

for svc in $SERVICES; do
  if changed_in "services/${svc}/"; then
    if ! command -v go &>/dev/null; then
      echo "  ⚠ go not found on PATH — skipping build for ${svc} (CI will catch it)"
      continue
    fi
    echo "  → go build: services/${svc}..."
    (cd "services/${svc}" && go build ./...) || {
      echo ""
      echo "✗ go build failed for ${svc}. Fix compile errors before pushing."
      exit 1
    }
    echo "  ✓ services/${svc} OK"
  fi
done

echo ""
echo "✓ pre-push checks passed."
