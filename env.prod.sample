# --- PostgreSQL (compose + migrate) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=IDL4Ssfdo9ettSaFfleZp4M+3vKA8wX2
POSTGRES_DB=umrohos
# Used by compose migrate service; must match credentials above and POSTGRES_DB.
DATABASE_URL=postgres://postgres:IDL4Ssfdo9ettSaFfleZp4M+3vKA8wX2@postgres:5432/umrohos?sslmode=disable

# One connection string for all Go services (overrides config.json.sample).
# Must match POSTGRES_* / DATABASE_URL.
POSTGRES_CONNECTION_STRING=postgres://postgres:IDL4Ssfdo9ettSaFfleZp4M+3vKA8wX2@postgres:5432/umrohos?sslmode=disable

