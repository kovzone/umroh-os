# Copy to the server as /home/infra/umrohos/.env.prod (never commit the real file).
# docker compose: docker compose -f docker-compose.prod.yml --env-file .env.prod <command>
#
# Longer template with comments: docs/deployment/env.prod.example
#
# --- PostgreSQL (compose + migrate) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=umrohos
DATABASE_URL=postgres://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/umrohos?sslmode=disable
POSTGRES_CONNECTION_STRING=postgres://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/umrohos?sslmode=disable

# --- core-web (Vite build args; public browser URL for API) ---
VITE_PUBLIC_GATEWAY_URL=http://216.176.238.161:4000
# Runtime app origin (SvelteKit CSRF/proxy-aware POST validation)
CORE_WEB_ORIGIN=http://216.176.238.161

# --- iam-svc (override config.json.sample secrets) ---
# Both must be exactly 32 characters long (raw string length), NOT openssl rand -base64 32 (that is ~44 chars).
# Generate two different values, e.g.: openssl rand -hex 16
TOKEN_KEY=CHANGE_ME_REPLACE_WITH_32_BYTE_PASETO_SECRET
TOTP_ENCRYPTION_KEY=CHANGE_ME_REPLACE_WITH_32_BYTE_AES_KEY

# --- Grafana (docker-compose.prod.yml — stack observability) ---
# Wajib diisi kalau compose memuat service grafana; pakai password kuat.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# --- Optional OTEL ---
# OTEL_TRACER_ENDPOINT=otel-collector:4317
